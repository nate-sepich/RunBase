---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import type { RunStore } from '../lib/types';

const store: RunStore = await import('../../data/runs.json').then(m => m.default);

// Sort: upcoming first (ascending), then past (most recent first)
const now = Date.now();
const upcoming = store.upcoming_events
  .filter(e => new Date(e.date).getTime() >= now)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const past = store.upcoming_events
  .filter(e => new Date(e.date).getTime() < now)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Horizon">
  <div class="mb-10">
    <h1 class="text-2xl font-semibold text-white">Horizon</h1>
    <p class="text-zinc-400 mt-1 text-sm">Upcoming races and target goals.</p>
  </div>

  {store.upcoming_events.length === 0 ? (
    <div class="border border-zinc-800 rounded-lg p-10 text-center">
      <p class="text-zinc-500 text-sm">
        No events scheduled. Add them to <code class="text-zinc-400">data/runs.json</code> under <code class="text-zinc-400">upcoming_events</code>.
      </p>
    </div>
  ) : (
    <div class="space-y-8">
      {upcoming.length > 0 && (
        <section>
          <h2 class="text-xs text-zinc-500 uppercase tracking-widest mb-4">Upcoming</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {upcoming.map(event => <EventCard event={event} />)}
          </div>
        </section>
      )}

      {past.length > 0 && (
        <section>
          <h2 class="text-xs text-zinc-500 uppercase tracking-widest mb-4">Past</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {past.map(event => <EventCard event={event} />)}
          </div>
        </section>
      )}
    </div>
  )}
</Layout>
