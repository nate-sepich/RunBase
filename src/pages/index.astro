---
import Layout from '../layouts/Layout.astro';
import ActivityCard from '../components/ActivityCard.astro';
import type { RunStore } from '../lib/types';
import { metersToMiles } from '../lib/format';

const store: RunStore = await import('../../data/runs.json').then(m => m.default);
const { athlete, activities, last_updated } = store;

// Summary stats
const totalMiles = activities.reduce((sum, a) => sum + metersToMiles(a.distance_meters), 0);
const totalRuns = activities.length;
const prCount = activities.filter(a => a.is_pr).length;
---

<Layout title="Timeline">
  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-2xl font-semibold text-white">{athlete.name}</h1>
    <p class="text-zinc-400 mt-1 text-sm">{athlete.bio}</p>
  </div>

  <!-- Summary stats -->
  <div class="grid grid-cols-3 gap-4 mb-10">
    <div class="border border-zinc-800 rounded-lg p-4">
      <div class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Total Miles</div>
      <div class="text-2xl font-semibold text-white">{totalMiles.toFixed(1)}</div>
    </div>
    <div class="border border-zinc-800 rounded-lg p-4">
      <div class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Activities</div>
      <div class="text-2xl font-semibold text-white">{totalRuns}</div>
    </div>
    <div class="border border-zinc-800 rounded-lg p-4">
      <div class="text-xs text-zinc-500 uppercase tracking-wider mb-1">PRs Set</div>
      <div class="text-2xl font-semibold text-white">{prCount}</div>
    </div>
  </div>

  <!-- Activity list -->
  {activities.length === 0 ? (
    <div class="border border-zinc-800 rounded-lg p-10 text-center">
      <p class="text-zinc-500 text-sm">No activities yet. Run the ETL to sync from Strava.</p>
    </div>
  ) : (
    <div class="space-y-3">
      {activities.map(activity => (
        <ActivityCard activity={activity} />
      ))}
    </div>
  )}

  <!-- Last updated -->
  <p class="text-xs text-zinc-600 mt-8 text-right">
    Last synced: {new Date(last_updated).toLocaleString('en-US', { timeZone: 'UTC' })} UTC
  </p>
</Layout>
