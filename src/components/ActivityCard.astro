---
import type { Activity } from '../lib/types';
import {
  metersToMiles,
  pacePerMile,
  formatDuration,
  formatDate,
  metersToFeet,
  typeLabel,
  typeColor,
  hrZone,
  zoneLabel,
  zoneBgColor,
  zoneTextColor,
} from '../lib/format';

// Load athlete config for max HR
import athleteConfig from '../../data/athlete.json';
const MAX_HR: number = athleteConfig.max_hr ?? 200;

export interface Props {
  activity: Activity;
}

const { activity } = Astro.props;

const miles = metersToMiles(activity.distance_meters);
const pace = pacePerMile(activity.average_speed_meters_per_second);
const duration = formatDuration(activity.moving_time_seconds);
const elevation = metersToFeet(activity.total_elevation_gain_meters);
const date = formatDate(activity.date);
const color = typeColor(activity.type);
const label = typeLabel(activity.type);
const postRunStatusColor = {
  matched: 'text-emerald-400 bg-emerald-400/10',
  modified: 'text-amber-400 bg-amber-400/10',
  off_plan: 'text-zinc-300 bg-zinc-300/10',
} as const;
---

<article class="border border-zinc-800 rounded-lg p-5 hover:border-zinc-700 transition-colors">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <!-- Header -->
      <div class="flex items-center gap-2 mb-1">
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${color}`}>
          {label}
        </span>
        {activity.is_pr && (
          <span class="text-xs font-medium px-2 py-0.5 rounded-full text-rose-400 bg-rose-400/10">
            PR {activity.pr_distance ? `· ${activity.pr_distance}` : ''}
          </span>
        )}
      </div>

      <!-- Name -->
      <h3 class="text-sm font-medium text-zinc-100 truncate">{activity.name}</h3>
      <p class="text-xs text-zinc-500 mt-0.5">{date}</p>
    </div>

    <!-- Distance -->
    <div class="text-right shrink-0">
      <div class="text-xl font-semibold text-white">{miles}</div>
      <div class="text-xs text-zinc-500">mi</div>
    </div>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-3 gap-3 mt-4 pt-4 border-t border-zinc-800/60">
    <div>
      <div class="text-xs text-zinc-500 mb-0.5">Pace</div>
      <div class="text-sm font-medium">{pace}<span class="text-xs text-zinc-500 ml-1">/mi</span></div>
    </div>
    <div>
      <div class="text-xs text-zinc-500 mb-0.5">Time</div>
      <div class="text-sm font-medium">{duration}</div>
    </div>
    <div>
      <div class="text-xs text-zinc-500 mb-0.5">Elev</div>
      <div class="text-sm font-medium">{elevation}<span class="text-xs text-zinc-500 ml-1">ft</span></div>
    </div>
  </div>

  <!-- Heart rate summary (if available) -->
  {(activity.average_heartrate || activity.max_heartrate) && (
    <div class="flex gap-4 mt-3 text-xs text-zinc-500">
      {activity.average_heartrate && (
        <span>Avg HR: <span class="text-zinc-300">{activity.average_heartrate} bpm</span></span>
      )}
      {activity.max_heartrate && (
        <span>Max HR: <span class="text-zinc-300">{activity.max_heartrate} bpm</span></span>
      )}
    </div>
  )}

  {activity.post_run?.adherence && (
    <div class="mt-3 pt-3 border-t border-zinc-800/60 space-y-2">
      <div class="flex items-center gap-2 flex-wrap">
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${postRunStatusColor[activity.post_run.adherence.status]}`}>
          {activity.post_run.adherence.status === 'matched' ? 'Plan matched' : activity.post_run.adherence.status === 'modified' ? 'Plan modified' : 'Off plan'}
        </span>
        {activity.post_run.matched_plan?.session?.type && (
          <span class="text-xs text-zinc-500">
            Planned: <span class="text-zinc-300">{activity.post_run.matched_plan.session.type.replace('_', ' ')}</span>
          </span>
        )}
      </div>
      <p class="text-xs text-zinc-400 leading-relaxed">{activity.post_run.adherence.summary}</p>
      {activity.post_run.reflection?.reply_text && (
        <div class="text-xs text-zinc-500">
          Reflection: <span class="text-zinc-300">{activity.post_run.reflection.reply_text}</span>
        </div>
      )}
    </div>
  )}

  <!-- Per-mile HR zone breakdown (if splits available) -->
  {activity.splits_standard && activity.splits_standard.length > 0 && (
    <details class="mt-3 group">
      <summary class="text-xs text-zinc-500 cursor-pointer select-none hover:text-zinc-300 transition-colors list-none flex items-center gap-1">
        <svg class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        Mile breakdown
      </summary>

      <div class="mt-2 space-y-1.5">
        <!-- Zone legend -->
        <div class="flex flex-wrap gap-x-3 gap-y-1 mb-2">
          {([1, 2, 3, 4, 5] as const).map(z => (
            <span class={`text-xs flex items-center gap-1 ${zoneTextColor(z)}`}>
              <span class={`inline-block w-2 h-2 rounded-full ${zoneBgColor(z)}`}></span>
              Z{z} {zoneLabel(z)}
            </span>
          ))}
        </div>

        {activity.splits_standard.map((split) => {
          const pace = pacePerMile(split.average_speed_meters_per_second);
          const hasHr = split.average_heartrate != null;
          const zone = hasHr ? hrZone(split.average_heartrate!, MAX_HR) : null;
          const barColor = zone ? zoneBgColor(zone) : 'bg-zinc-700';
          const hrPct = hasHr ? Math.min(Math.round((split.average_heartrate! / MAX_HR) * 100), 100) : 0;

          return (
            <div class="flex items-center gap-2 text-xs">
              <!-- Mile label -->
              <span class="text-zinc-500 w-8 shrink-0">mi {split.mile}</span>

              <!-- HR zone bar -->
              <div class="flex-1 h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                {hasHr && (
                  <div
                    class={`h-full rounded-full ${barColor} transition-all`}
                    style={`width: ${hrPct}%`}
                  />
                )}
              </div>

              <!-- HR bpm -->
              <span class={`w-16 text-right shrink-0 ${zone ? zoneTextColor(zone) : 'text-zinc-600'}`}>
                {hasHr ? `${split.average_heartrate} bpm` : '— bpm'}
              </span>

              <!-- Pace -->
              <span class="w-14 text-right shrink-0 text-zinc-400">{pace}/mi</span>
            </div>
          );
        })}
      </div>
    </details>
  )}
</article>
