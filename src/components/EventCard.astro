---
import type { UpcomingEvent } from '../lib/types';
import { formatDate } from '../lib/format';

export interface Props {
  event: UpcomingEvent;
}

const { event } = Astro.props;

const date = formatDate(event.date);
const daysUntil = Math.ceil((new Date(event.date).getTime() - Date.now()) / (1000 * 60 * 60 * 24));
const isPast = daysUntil < 0;
const isClose = daysUntil >= 0 && daysUntil <= 14;
---

<article class={[
  'border rounded-lg p-5 transition-colors',
  isPast
    ? 'border-zinc-800/40 opacity-50'
    : isClose
    ? 'border-amber-800/60 hover:border-amber-700/60'
    : 'border-zinc-800 hover:border-zinc-700',
].join(' ')}>
  <!-- Header -->
  <div class="flex items-start justify-between gap-4 mb-4">
    <div>
      <h3 class="font-semibold text-zinc-100">{event.event_name}</h3>
      <p class="text-sm text-zinc-500 mt-0.5">{event.location}</p>
    </div>
    <div class="text-right shrink-0">
      {!isPast && (
        <div class={`text-sm font-medium ${isClose ? 'text-amber-400' : 'text-zinc-300'}`}>
          {daysUntil === 0 ? 'Today' : `${daysUntil}d`}
        </div>
      )}
      <div class="text-xs text-zinc-500">{date}</div>
    </div>
  </div>

  <!-- Distance -->
  <div class="text-xs text-zinc-500 mb-3 uppercase tracking-wider">{event.target_distance}</div>

  <!-- Goals -->
  <div class="space-y-1.5">
    <div class="flex items-baseline gap-2">
      <span class="text-xs font-medium text-emerald-400 w-5">A</span>
      <span class="text-sm text-zinc-200">{event.a_goal}</span>
    </div>
    <div class="flex items-baseline gap-2">
      <span class="text-xs font-medium text-blue-400 w-5">B</span>
      <span class="text-sm text-zinc-400">{event.b_goal}</span>
    </div>
  </div>
</article>
