---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Gabe\'s running portfolio.' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const nav = [
  { href: `${base}/`, label: 'Timeline' },
  { href: `${base}/prs`, label: 'PR Board' },
  { href: `${base}/horizon`, label: 'Horizon' },
  { href: `${base}/plan`, label: 'Plan' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — RunBase</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen font-mono antialiased">
    <!-- Nav -->
    <header class="border-b border-zinc-800/60 sticky top-0 z-10 bg-zinc-950/90 backdrop-blur-sm">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={`${base}/`} class="text-white font-semibold tracking-widest text-sm uppercase">
          RunBase
        </a>
        <nav class="flex items-center gap-1">
          {nav.map(({ href, label }) => {
            const active = currentPath === href || (href !== `${base}/` && currentPath.startsWith(href));
            return (
              <a
                href={href}
                class={[
                  'px-3 py-1.5 rounded text-sm transition-colors',
                  active
                    ? 'text-white bg-zinc-800'
                    : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/50',
                ].join(' ')}
              >
                {label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main class="max-w-4xl mx-auto px-6 py-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/60 mt-20">
      <div class="max-w-4xl mx-auto px-6 py-6 flex items-center justify-between text-zinc-600 text-xs">
        <span>RunBase</span>
        <span>Powered by Strava</span>
      </div>
    </footer>
  </body>
</html>
